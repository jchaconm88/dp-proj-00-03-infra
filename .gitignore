# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files
*.tfplan

# Terraform lock files (keep .terraform.lock.hcl, ignore .terraform dir)
.terraform/

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log files
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
!environments/*.tfvars.example

# Local .env files
seed/.env
.env
.env.*
!.env.example

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
