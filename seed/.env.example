# Proyecto GCP seed (crear manualmente; solo state y factory de proyectos por sufijo)
SEED_GCP_PROJECT_ID=dp-proj-00-03-seed
SEED_TF_STATE_BUCKET=dp-proj-00-03-seed-tfstate

BILLING_ACCOUNT_ID=012345-678901-ABCDEF
# FOLDER_ID=folders/123456789012

GCP_REGION=us-central1
NEON_API_KEY=tu-neon-api-key
# Consola Neon > Organization settings > Organization ID
NEON_ORG_ID=org-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ALERT_EMAIL=ops@tu-dominio.com

# Sufijos a desplegar tras bootstrap (coma). Vacio = todos los de suffixes.auto.tfvars
